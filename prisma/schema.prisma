generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String
  role      Role     @default(TECNICO)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Case {
  id           String   @id @default(cuid())
  type         String   // TRC o LCD/LED
  brand        String
  modelChassis String
  symptom      String
  descarte     String?
  solution     String
  mediaLinks   String[] @default([])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([type, brand, modelChassis, symptom])
}

enum Role {
  ADMIN
  TECNICO
}
